# ShamGP 商城项目 - 环境变量示例
# 复制此文件为 .env 并根据需要修改

# ==================== 数据库配置 ====================
# 可选值: sqlite, mysql, postgresql
# 默认: sqlite（开发环境推荐）
DB_TYPE=sqlite

# MySQL/PostgreSQL 配置（DB_TYPE 为 sqlite 时忽略）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=shop_db

# ==================== JWT 配置 ====================
# 生产环境请务必修改此密钥！
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
# Token 过期时间（分钟），默认 7 天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== 后端配置 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== 开发模式配置 ====================
# 路由导入严格模式：true=失败时抛出异常，false=静默跳过
API_STRICT_MODE=false
