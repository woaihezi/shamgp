# ShamGP 商城项目 - 环境变量示例
# 复制此文件为 .env 并根据需要修改

# ==================== 数据库配置 ====================
# 可选值: sqlite, mysql, postgresql
# 默认: sqlite（开发环境推荐）
DB_TYPE=sqlite

# MySQL/PostgreSQL 配置（DB_TYPE 为 sqlite 时忽略）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=shop_db

# ==================== JWT 配置 ====================
# 生产环境请务必修改此密钥！
# 要求：至少 32 位随机字符串，不要使用默认占位值
SECRET_KEY=CHANGE_ME_TO_A_32_PLUS_CHAR_RANDOM_SECRET
ALGORITHM=HS256
# Token 过期时间（分钟），默认 7 天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== 后端配置 ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==================== CORS 配置（P0） ====================
# 开发环境示例（admin + shop）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# 生产环境示例（按实际域名替换）
# CORS_ORIGINS=https://admin.example.com,https://shop.example.com
# 如需携带 Cookie/认证头，必须保持 allow_origins 为明确白名单，不能使用 *
CORS_ALLOW_CREDENTIALS=true

# ==================== 开发模式配置 ====================
# 路由导入严格模式：true=失败时抛出异常，false=静默跳过
API_STRICT_MODE=false
